hub.com/repos/AdguardTeam/AdguardFilters/labels/NSFW","name":"NSFW","color":"ff9900","default":false,"description":"Nudes and porn sites"},{"id":762661226,"node_id":"MDU6TGFiZWw3NjI2NjEyMjY=","url":"https://api.github.com/repos/AdguardTeam/AdguardFilters/labels/N:%20AdGuard%20for%20Mac","name":"N: AdGuard for Mac","color":"a64d79","default":false,"description":null},{"id":762661276,"node_id":"MDU6TGFiZWw3NjI2NjEyNzY=","url":"https://api.github.com/repos/AdguardTeam/AdguardFilters/labels/N:%20AdGuard%20for%20iOS","name":"N: AdGuard for iOS","color":"8e7cc3","default":false,"description":null},{"id":766811254,"node_id":"MDU6TGFiZWw3NjY4MTEyNTQ=","url":"https://api.github.com/repos/AdguardTeam/AdguardFilters/labels/N:%20AdGuard%20Browser%20Extension","name":"N: AdGuard Browser Extension","color":"b6d7a8","default":false,"description":null},{"id":989137587,"node_id":"MDU6TGFiZWw5ODkxMzc1ODc=","url":"https://api.github.com/repos/AdguardTeam/AdguardFilters/labels/N:%20Other","name":"N: Other","color":"ededed","default":false,"description":"Non-AdGuard ad blocker"},{"id":1564392165,"node_id":"MDU6TGFiZWwxNTY0MzkyMTY1","url":"https://api.github.com/repos/AdguardTeam/AdguardFilters/labels/A:%20Problematic","name":"A: Problematic","color":"0b0059","default":false,"description":"Issues, which cannot be resolved easily"},{"id":2160851735,"node_id":"MDU6TGFiZWwyMTYwODUxNzM1","url":"https://api.github.com/repos/AdguardTeam/AdguardFilters/labels/N:%20AdGuard%20for%20Safari","name":"N: AdGuard for Safari","color":"584eb2","default":false,"description":""},{"id":9467961679,"node_id":"LA_kwDOAVlsM88AAAACNFWhTw","url":"https://api.github.com/repos/AdguardTeam/AdguardFilters/labels/N:%20AdGuard%20Mini%20for%20Mac","name":"N: AdGuard Mini for Mac","color":"ededed","default":false,"description":null}],"state":"open","locked":false,"assignees":[],"milestone":null,"comments":754,"created_at":"2025-04-15T13:51:43Z","updated_at":"2026-04-07T00:21:02Z","closed_at":null,"assignee":null,"type":null,"active_lock_reason":null,"sub_issues_summary":{"total":0,"completed":0,"percent_completed":0},"issue_dependencies_summary":{"blocked_by":0,"total_blocked_by":0,"blocking":0,"total_blocking":0},"body":"# ATTENTION\n\n> [!NOTE]  \n> YouTube changes their detection scripts regularly. That means that sometime you can face the detection message.\n> If all the following instructions do not work, please **email filters@adguard.com** or wait until any update is available. \n\n> [!CAUTION] \n> Please do not use another adblocker in the same time because using another adblocker can delay/lags the YouTube loading (e.g., AdBlock Plus and AdBlock)[^1] OR interfere AdGuard's filtering functionality.\n\n> [!CAUTION] \n> Please do not use an userscript related to the bypassing YouTube detection message like [TheRealJoelmatic/RemoveAdblockThing](https://github.com/TheRealJoelmatic/RemoveAdblockThing).\n> Recently, YouTube anti-adblock script added infinite dummy advertisements to try to neutralize the userscript. ( [TheRealJoelmatic/RemoveAdblockThing#264](https://github.com/TheRealJoelmatic/RemoveAdblockThing/issues/264) )\n\n> [!WARNING]\n> Please check that there no another web browser extension that has adblocking feature is enabled on your web browser. It can interfere AdGuard's filtering functionality.\n\n> [!IMPORTANT]  \n> Saving memory feature of your web browser or sleep feature of your operating system can interfere AdGuard's filtering functionality.\n> In this case, please re-enable AdGuard's filtering by toggling the protection toggle.\n> Following the instructions can be needed.\n\n### The instructions\n1. Force to update the filters by clicking the reload button in AdGuard Browser Extension/AdGuard mobile or update tray menu in your system tray. [^2]\n2. Reload the YouTube webpage without cache by pressing <kbd>Ctrl</kbd> + <kbd>Shift</kbd> + <kbd>R</kbd> [^3].\n3. Clear cache, cookies and site data of your web browser.\n4. Re-open your web browser completely (checking your system monitor[^4] will be better).\n\n[^1]: https://gitlab.com/adblockinc/ext/adblockplus/adblockplusui/-/issues/1576\n[^2]: [AdGuard for Windows](https://adguard.com/kb/adguard-for-windows/overview/#tray-menu); [AdGuard for Mac](https://adguard.com/kb/adguard-for-mac/overview/#updates-check); \n[^3]: On macOS, <kbd>Command</kbd> + <kbd>Shift</kbd> + <kbd>R</kbd>\n[^4]: Task Manager on Windows, System Monitor on GNOME Shell, KDE System Guard on KDE Plasma or Activity Monitor on macOS. \n\n\nPrevious issue https://github.com/AdguardTeam/AdguardFilters/issues/198973","reactions":{"url":"https://api.github.com/repos/AdguardTeam/AdguardFilters/issues/203236/reactions","total_count":5,"+1":2,"-1":2,"laugh":0,"hooray":0,"confused":1,"heart":0,"rocket":0,"eyes":0},"timeline_url":"https://api.github.com/repos/AdguardTeam/AdguardFilters/issues/203236/timeline","performed_via_github_app":null,"state_reason":"reopened","pinned_comment":null},"comment":{"url":"https://api.github.com/repos/AdguardTeam/AdguardFilters/issues/comments/4195719161","html_url":"https://github.com/AdguardTeam/AdguardFilters/issues/203236#issuecomment-4195719161","issue_url":"https://api.github.com/repos/AdguardTeam/AdguardFilters/issues/203236","id":4195719161,"node_id":"IC_kwDOAVlsM876FZf5","user":{"login":"adguard-bot","id":30082422,"node_id":"MDQ6VXNlcjMwMDgyNDIy","avatar_url":"https://avatars.githubusercontent.com/u/30082422?v=4","gravatar_id":"","url":"https://api.github.com/users/adguard-bot","html_url":"https://github.com/adguard-bot","followers_url":"https://api.github.com/users/adguard-bot/followers","following_url":"https://api.github.com/users/adguard-bot/following{/other_user}","gists_url":"https://api.github.com/users/adguard-bot/gists{/gist_id}","starred_url":"https://api.github.com/users/adguard-bot/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/adguard-bot/subscriptions","organizations_url":"https://api.github.com/users/adguard-bot/orgs","repos_u